# ── Gate (the single shared entry code) ─────────────────────────────
GATE_CODE=bali-2026                 # the code everyone types to get in
SESSION_SECRET=replace-with-a-long-random-string   # signs the gate cookie
GATE_MAX_ATTEMPTS=5                 # failed tries before lockout
GATE_WINDOW_MINUTES=15             # lockout window

# ── Supabase ────────────────────────────────────────────────────────
# For local dev, run `npm run db:start` and copy the printed values here.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
