# ── Gate (the single shared entry code) ─────────────────────────────
GATE_CODE=bali-2026                 # the code everyone types to get in
SESSION_SECRET=replace-with-a-long-random-string   # signs the gate cookie
GATE_MAX_ATTEMPTS=5                 # failed tries before lockout
GATE_WINDOW_MINUTES=15             # lockout window

# ── Supabase ────────────────────────────────────────────────────────
# For local dev, run `npm run db:start` and copy the printed values here.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ── Location-aware accommodation scoring (off by default) ───────────
# Master flag. Off → the board behaves exactly as before and runs NO places
# query, so an un-migrated DB is untouched. Apply the migrations (and confirm
# bali.places is in pg_publication_tables) BEFORE turning this on.
LOCATION_SCORING_ENABLED=false
# Geocoding (server-only, OPTIONAL). Without a key, addresses stay "Needs
# location" and the board falls back to manual coordinates + haversine — fully
# usable, just approximate. NEVER prefix these with NEXT_PUBLIC_ (server-only).
# LocationIQ's free tier permits storing the returned coordinates.
LOCATIONIQ_API_KEY=
# Routing for real per-mode (scooter/foot/car) times (Phase 2, server-only,
# OPTIONAL). Without it, all modes use the haversine estimate.
VALHALLA_BASE_URL=
